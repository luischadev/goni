---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import TextLink from "../components/ui/TextLink.astro";
import { cms } from "../lib/cms";

const settings = await cms.getSiteSettings();
const areas = await cms.getPracticeAreas();
---

<BaseLayout
  title="Contacto"
  description="Contacte a Goñi & Cía. Abogados. Coordinamos una reunión inicial para evaluar su caso o programa de seguros."
>
  <section class="container-x pt-20 md:pt-32 pb-12 md:pb-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16">
      <div class="md:col-span-8">
        <p class="eyebrow reveal">Contacto</p>
        <h1 class="font-display text-5xl md:text-7xl lg:text-[80px] leading-[1.02] mt-8 reveal">
          Conversemos sobre la operación legal de su empresa.
        </h1>
        <p class="mt-10 max-w-2xl text-base md:text-lg text-fg-muted leading-relaxed reveal">
          Coordinamos una reunión inicial, sin compromiso, para entender el contexto
          de su empresa o aseguradora, los riesgos críticos y la mejor forma de
          articular una asesoría que aporte valor desde el primer día.
        </p>
      </div>
    </div>
  </section>

  <section class="border-y border-line">
    <div class="container-x py-20 md:py-28">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16">
        <div class="md:col-span-5">
          <p class="eyebrow reveal">Datos de contacto</p>

          <div class="mt-10 space-y-10 reveal">
            <div>
              <p class="text-xs uppercase tracking-[var(--tracking-eyebrow)] text-fg-subtle">
                Oficina
              </p>
              <address class="not-italic mt-4 text-base md:text-lg text-fg-soft leading-relaxed">
                {settings.address.street}<br />
                {settings.address.city}<br />
                {settings.address.region}, {settings.address.country}
              </address>
            </div>

            <div>
              <p class="text-xs uppercase tracking-[var(--tracking-eyebrow)] text-fg-subtle">
                Email
              </p>
              <a
                href={`mailto:${settings.email}`}
                class="mt-4 inline-block font-display text-2xl md:text-3xl text-fg hover:text-fg-accent transition-colors"
              >
                {settings.email}
              </a>
            </div>

            <div>
              <p class="text-xs uppercase tracking-[var(--tracking-eyebrow)] text-fg-subtle">
                Teléfono
              </p>
              <a
                href={`tel:${settings.phone.replace(/\s+/g, "")}`}
                class="mt-4 inline-block font-display text-2xl md:text-3xl text-fg hover:text-fg-accent transition-colors"
              >
                {settings.phone}
              </a>
            </div>

            <div>
              <p class="text-xs uppercase tracking-[var(--tracking-eyebrow)] text-fg-subtle">
                Horario de atención
              </p>
              <p class="mt-4 text-base text-fg-soft leading-relaxed">
                Lunes a viernes<br />
                09:00 – 18:30 hrs.
              </p>
            </div>
          </div>
        </div>

        <div class="md:col-span-6 md:col-start-7">
          <p class="eyebrow reveal">Formulario de consulta</p>

          <form
            class="mt-10 space-y-7 reveal"
            method="POST"
            action="#"
            name="contact"
          >
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-xs uppercase tracking-[var(--tracking-eyebrow)] text-fg-muted mb-3">
                  Nombre completo
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full bg-transparent border-b border-fg-subtle/40 focus:border-line-strong py-3 text-base text-fg outline-none transition-colors placeholder:text-fg-subtle"
                  placeholder="Nombre y apellido"
                />
              </div>
              <div>
                <label for="company" class="block text-xs uppercase tracking-[var(--tracking-eyebrow)] text-fg-muted mb-3">
                  Empresa
                </label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  class="w-full bg-transparent border-b border-fg-subtle/40 focus:border-line-strong py-3 text-base text-fg outline-none transition-colors placeholder:text-fg-subtle"
                  placeholder="Empresa u organización"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="email" class="block text-xs uppercase tracking-[var(--tracking-eyebrow)] text-fg-muted mb-3">
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full bg-transparent border-b border-fg-subtle/40 focus:border-line-strong py-3 text-base text-fg outline-none transition-colors placeholder:text-fg-subtle"
                  placeholder="nombre@empresa.cl"
                />
              </div>
              <div>
                <label for="phone" class="block text-xs uppercase tracking-[var(--tracking-eyebrow)] text-fg-muted mb-3">
                  Teléfono
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full bg-transparent border-b border-fg-subtle/40 focus:border-line-strong py-3 text-base text-fg outline-none transition-colors placeholder:text-fg-subtle"
                  placeholder="+56 9 0000 0000"
                />
              </div>
            </div>

            <div>
              <label for="area" class="block text-xs uppercase tracking-[var(--tracking-eyebrow)] text-fg-muted mb-3">
                Área de interés
              </label>
              <select
                id="area"
                name="area"
                class="w-full bg-transparent border-b border-fg-subtle/40 focus:border-line-strong py-3 text-base text-fg outline-none transition-colors"
              >
                <option value="">Seleccione un área</option>
                {areas.map((area) => (
                  <option value={area.slug}>{area.title}</option>
                ))}
                <option value="otro">Otra consulta</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-xs uppercase tracking-[var(--tracking-eyebrow)] text-fg-muted mb-3">
                Cuéntenos brevemente su caso
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full bg-transparent border-b border-fg-subtle/40 focus:border-line-strong py-3 text-base text-fg outline-none transition-colors placeholder:text-fg-subtle resize-none"
                placeholder="Describa el contexto, los actores involucrados y el resultado esperado."
              ></textarea>
            </div>

            <p class="text-xs text-fg-muted leading-relaxed">
              Al enviar este formulario acepta nuestra política de confidencialidad.
              Le responderemos en un plazo máximo de 48 horas hábiles.
            </p>

            <Button type="submit" size="lg">Enviar consulta</Button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-inverse text-fg-on-inverse">
    <div class="container-x py-20 md:py-28">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-center">
        <div class="md:col-span-7">
          <p class="eyebrow text-fg-on-inverse-accent reveal">Ubicación</p>
          <h2 class="font-display text-3xl md:text-5xl mt-6 leading-[1.05] text-fg-on-inverse reveal">
            {settings.address.street}<br />
            {settings.address.city}, {settings.address.country}
          </h2>
          <p class="mt-8 max-w-xl text-fg-on-inverse/75 leading-relaxed reveal">
            Nuestras oficinas se ubican en el corazón financiero y legal de
            Providencia, con acceso directo a metro y estacionamientos cercanos.
          </p>
        </div>
        <div class="md:col-span-4 md:col-start-9 reveal">
          <TextLink
            href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
              `${settings.address.street}, ${settings.address.city}, ${settings.address.country}`
            )}`}
            variant="inverse"
            target="_blank"
            rel="noopener noreferrer"
          >
            Ver en Google Maps
          </TextLink>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
