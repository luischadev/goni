---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import { cms } from "../lib/cms";

const settings = await cms.getSiteSettings();
const areas = await cms.getPracticeAreas();

const fieldGroupClass = "space-y-2";
const labelClass = "block text-sm font-medium leading-none text-fg-muted";
const helperClass = "text-xs leading-relaxed text-fg-muted";
const fieldClass =
  "contact-field-input w-full min-h-12 bg-surface-soft border border-transparent border-b-line px-4 py-3 text-base leading-normal text-fg outline-none transition-colors duration-200 placeholder:text-fg-subtle hover:border-b-line-strong focus:[border-color:var(--color-fg-accent)] focus:hover:[border-color:var(--color-fg-accent)] disabled:cursor-not-allowed disabled:bg-surface-soft/60 disabled:text-fg-subtle";
const textareaClass = `${fieldClass} min-h-36 resize-none overflow-hidden`;
const contactFieldClass = `${fieldGroupClass} contact-field`;
const selectClass = `${fieldClass} appearance-none pr-12`;
---

<BaseLayout
  title="Contacto"
  description="Contacte a Goñi & Cía. Abogados. Coordinamos una reunión inicial para evaluar su caso o programa de seguros."
>
  <section class="container-x pt-20 md:pt-32 pb-12 md:pb-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16">
      <div class="md:col-span-8">
        <p class="eyebrow reveal">Contacto</p>
        <h1 class="font-display text-5xl md:text-7xl lg:text-[80px] leading-[1.02] mt-8 reveal">
          Conversemos sobre la operación legal de su empresa.
        </h1>
        <p class="mt-10 max-w-2xl text-base md:text-lg text-fg-muted leading-relaxed reveal">
          Coordinamos una reunión inicial, sin compromiso, para entender el contexto
          de su empresa o aseguradora, los riesgos críticos y la mejor forma de
          articular una asesoría que aporte valor desde el primer día.
        </p>
      </div>
    </div>
  </section>

  <section class="border-y border-line">
    <div class="container-x py-20 md:py-28">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16">
        <div class="md:col-span-5">
          <p class="eyebrow reveal">Datos de contacto</p>

          <div class="mt-10 space-y-10 reveal">
            <div>
              <p class="text-xs uppercase tracking-[var(--tracking-eyebrow)] text-fg-subtle">
                Oficina
              </p>
              <address class="not-italic mt-4 text-base md:text-lg text-fg-soft leading-relaxed">
                {settings.address.street}<br />
                {settings.address.city}<br />
                {settings.address.region}, {settings.address.country}
              </address>
            </div>

            <div>
              <p class="text-xs uppercase tracking-[var(--tracking-eyebrow)] text-fg-subtle">
                Email
              </p>
              <a
                href={`mailto:${settings.email}`}
                class="mt-4 inline-block font-display text-2xl md:text-3xl text-fg hover:text-fg-accent transition-colors"
              >
                {settings.email}
              </a>
            </div>

            <div>
              <p class="text-xs uppercase tracking-[var(--tracking-eyebrow)] text-fg-subtle">
                Teléfono
              </p>
              <a
                href={`tel:${settings.phone.replace(/\s+/g, "")}`}
                class="mt-4 inline-block font-display text-2xl md:text-3xl text-fg hover:text-fg-accent transition-colors"
              >
                {settings.phone}
              </a>
            </div>

            <div>
              <p class="text-xs uppercase tracking-[var(--tracking-eyebrow)] text-fg-subtle">
                Horario de atención
              </p>
              <p class="mt-4 text-base text-fg-soft leading-relaxed">
                Lunes a viernes<br />
                09:00 – 18:30 hrs.
              </p>
            </div>
          </div>
        </div>

        <div class="md:col-span-6 md:col-start-7">
          <p class="eyebrow reveal">Formulario de consulta</p>

          <form
            class="contact-form mt-10 space-y-7 reveal"
            method="POST"
            action="#"
            name="contact"
            data-contact-form
            novalidate
          >
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class={contactFieldClass} data-contact-field>
                <label for="name" class={labelClass}>
                  Nombre completo
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class={fieldClass}
                  data-contact-input
                  placeholder="Nombre y apellido"
                  aria-describedby="name-helper name-error-helper"
                />
                <p id="name-helper" class={`${helperClass} contact-helper-default`}>
                  Ingrese nombre y apellido.
                </p>
                <p id="name-error-helper" class={`${helperClass} contact-helper-invalid`}>
                  Ingrese su nombre completo.
                </p>
              </div>
              <div class={fieldGroupClass}>
                <label for="company" class={labelClass}>
                  Empresa <span class="text-fg-subtle">(opcional)</span>
                </label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  class={fieldClass}
                  placeholder="Empresa u organización"
                  aria-describedby="company-helper"
                />
                <p id="company-helper" class={helperClass}>
                  Indique su empresa u organización si corresponde.
                </p>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class={contactFieldClass} data-contact-field>
                <label for="email" class={labelClass}>
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class={fieldClass}
                  data-contact-input
                  placeholder="nombre@empresa.cl"
                  aria-describedby="email-helper email-format-helper"
                />
                <p id="email-helper" class={`${helperClass} contact-helper-default`}>
                  Usaremos este correo para responder su consulta.
                </p>
                <p id="email-format-helper" class={`${helperClass} contact-helper-invalid`}>
                  Ingrese un email válido, por ejemplo nombre@empresa.cl.
                </p>
              </div>
              <div class={fieldGroupClass}>
                <label for="phone" class={labelClass}>
                  Teléfono <span class="text-fg-subtle">(opcional)</span>
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class={fieldClass}
                  placeholder="+56 9 0000 0000"
                  aria-describedby="phone-helper"
                />
                <p id="phone-helper" class={helperClass}>
                  Incluya código de país si corresponde.
                </p>
              </div>
            </div>

            <div class={fieldGroupClass}>
              <label for="area" class={labelClass}>
                Área de interés <span class="text-fg-subtle">(opcional)</span>
              </label>
              <div class="relative">
                <select
                  id="area"
                  name="area"
                  class={selectClass}
                  aria-describedby="area-helper"
                >
                  <option value="">Seleccione un área</option>
                  {areas.map((area) => (
                    <option value={area.slug}>{area.title}</option>
                  ))}
                  <option value="otro">Otra consulta</option>
                </select>
                <span
                  class="material-symbols-sharp pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-xl leading-none text-fg-muted"
                  aria-hidden="true"
                >
                  expand_more
                </span>
              </div>
              <p id="area-helper" class={helperClass}>
                Seleccione el frente principal de su consulta.
              </p>
            </div>

            <div class={contactFieldClass} data-contact-field>
              <label for="message" class={labelClass}>
                Cuéntenos brevemente su caso
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class={textareaClass}
                data-contact-input
                placeholder="Describa el contexto, los actores involucrados y el resultado esperado."
                aria-describedby="message-helper message-error-helper"
              ></textarea>
              <p id="message-helper" class={`${helperClass} contact-helper-default`}>
                Resuma el contexto, los actores involucrados y el resultado esperado.
              </p>
              <p id="message-error-helper" class={`${helperClass} contact-helper-invalid`}>
                Cuéntenos brevemente su caso para poder responderle.
              </p>
            </div>

            <Button type="submit" size="lg">Enviar consulta</Button>
          </form>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style is:global>
  .contact-form {
    --contact-error-color: #7a1f2b;
  }

  .contact-field .contact-helper-invalid {
    color: var(--contact-error-color);
    display: none;
  }

  .contact-field.field-error .contact-field-input {
    border-color: var(--contact-error-color);
  }

  .contact-field.field-error .contact-field-input:hover,
  .contact-field.field-error .contact-field-input:focus,
  .contact-field.field-error .contact-field-input:focus:hover {
    border-color: var(--contact-error-color);
  }

  .contact-field.field-error .contact-helper-default {
    display: none;
  }

  .contact-field.field-error .contact-helper-invalid {
    display: block;
  }
</style>

<script>
  function initContactForm() {
    const form = document.querySelector("[data-contact-form]");
    if (!(form instanceof HTMLFormElement)) return;
    if (form.dataset.initialized === "true") return;
    form.dataset.initialized = "true";

    const fields = form.querySelectorAll("[data-contact-input][required]");

    const resizeTextarea = (field) => {
      if (!(field instanceof HTMLTextAreaElement)) return;

      field.style.height = "auto";
      field.style.height = `${field.scrollHeight}px`;
    };

    const validateField = (field, showAll = false) => {
      if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement)) {
        return false;
      }

      const group = field.closest("[data-contact-field]");
      if (!(group instanceof HTMLElement)) return false;

      const hasValue = field.value.trim() !== "";
      const isTouched = field.dataset.touched === "true";
      const isInvalid = !field.checkValidity();
      const showError =
        showAll ? isInvalid : isInvalid && (hasValue || (isTouched && field.required));

      group.classList.toggle("field-error", showError);
      field.setAttribute("aria-invalid", showError ? "true" : "false");

      return showError;
    };

    fields.forEach((field) => {
      resizeTextarea(field);

      field.addEventListener("input", () => {
        if (field.value.trim() !== "") {
          field.dataset.touched = "true";
        }
        resizeTextarea(field);
        validateField(field);
      });

      field.addEventListener("blur", () => {
        field.dataset.touched = "true";
        validateField(field);
      });
    });

    form.addEventListener("submit", (event) => {
      let hasError = false;

      fields.forEach((field) => {
        field.dataset.touched = "true";
        if (validateField(field, true)) {
          hasError = true;
        }
      });

      if (hasError) {
        event.preventDefault();
        const firstInvalid = form.querySelector(
          "[data-contact-field].field-error [data-contact-input]"
        );
        if (firstInvalid instanceof HTMLElement) {
          firstInvalid.focus();
        }
      }
    });
  }

  initContactForm();
  document.addEventListener("astro:page-load", initContactForm);
</script>
