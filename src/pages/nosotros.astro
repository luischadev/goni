---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import Sheet from "../components/ui/Sheet.astro";
import Timeline from "../components/ui/Timeline.astro";
import CTASection from "../components/CTASection.astro";
import { cms } from "../lib/cms";

const team = await cms.getTeamMembers();
---

<BaseLayout
  title="Nosotros"
  description="Conozca al equipo de Goñi & Cía. Abogados: socios, abogados jefes y especialistas con trayectoria en seguros, responsabilidad civil y derecho de transporte."
>
  <!-- ── Hero ────────────────────────────────────────────────── -->
  <section class="container-x pt-20 md:pt-32 pb-24 md:pb-32">
    <div class="max-w-5xl">
      <h1 class="font-display text-5xl md:text-7xl leading-[1.02] reveal">
        Un estudio boutique, construido sobre conocimiento técnico y trato cercano.
      </h1>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-12 md:gap-12 mt-16 md:mt-24 pt-16 border-t border-line">
      <div class="reveal">
        <span class="material-symbols-sharp text-5xl text-fg-accent leading-none" aria-hidden="true">
          architecture
        </span>
        <h3 class="font-display text-2xl mt-6 leading-[1.15]">Profundidad técnica</h3>
        <p class="mt-4 text-sm md:text-base text-fg-muted leading-relaxed">
          Nuestra práctica nace del conocimiento profundo de las industrias que
          asesoramos. Hablamos el lenguaje del negocio, no solo el del derecho.
        </p>
      </div>
      <div class="reveal">
        <span class="material-symbols-sharp text-5xl text-fg-accent leading-none" aria-hidden="true">
          handshake
        </span>
        <h3 class="font-display text-2xl mt-6 leading-[1.15]">Trato cercano</h3>
        <p class="mt-4 text-sm md:text-base text-fg-muted leading-relaxed">
          Como estudio boutique, cada cliente tiene acceso directo a los socios
          y a un equipo que conoce su operación de extremo a extremo.
        </p>
      </div>
      <div class="reveal">
        <span class="material-symbols-sharp text-5xl text-fg-accent leading-none" aria-hidden="true">
          verified
        </span>
        <h3 class="font-display text-2xl mt-6 leading-[1.15]">Resultados consistentes</h3>
        <p class="mt-4 text-sm md:text-base text-fg-muted leading-relaxed">
          Más de tres décadas asesorando al mercado asegurador y logístico nos
          han enseñado que la consistencia es el mejor capital de un estudio.
        </p>
      </div>
      <div class="reveal">
        <span class="material-symbols-sharp text-5xl text-fg-accent leading-none" aria-hidden="true">
          query_stats
        </span>
        <h3 class="font-display text-2xl mt-6 leading-[1.15]">Criterio estratégico</h3>
        <p class="mt-4 text-sm md:text-base text-fg-muted leading-relaxed">
          Ordenamos escenarios complejos para que cada decisión legal tenga una
          lectura clara de riesgos, tiempos y efectos comerciales.
        </p>
      </div>
      <div class="reveal">
        <span class="material-symbols-sharp text-5xl text-fg-accent leading-none" aria-hidden="true">
          groups
        </span>
        <h3 class="font-display text-2xl mt-6 leading-[1.15]">Equipo involucrado</h3>
        <p class="mt-4 text-sm md:text-base text-fg-muted leading-relaxed">
          Cada asunto se trabaja con socios y abogados que conocen el caso,
          evitando capas innecesarias entre el cliente y la estrategia.
        </p>
      </div>
      <div class="reveal">
        <span class="material-symbols-sharp text-5xl text-fg-accent leading-none" aria-hidden="true">
          timeline
        </span>
        <h3 class="font-display text-2xl mt-6 leading-[1.15]">Seguimiento constante</h3>
        <p class="mt-4 text-sm md:text-base text-fg-muted leading-relaxed">
          Mantenemos una gestión ordenada de hitos, antecedentes y próximos pasos
          para que el cliente siempre sepa dónde está parado.
        </p>
      </div>
    </div>
  </section>

  <!-- ── El equipo ───────────────────────────────────────────── -->
  <section
    class="scroll-background-section scroll-background--surface-soft"
    data-scroll-background
    data-scroll-background-start="top 35%"
    data-scroll-background-end="bottom 30%"
  >
    <div class="container-x py-24 md:py-32">
      <div class="mb-16 md:mb-20">
        <p class="eyebrow reveal">El equipo</p>
        <h2 class="font-display text-4xl md:text-6xl mt-6 leading-[1.05] reveal max-w-2xl">
          Abogados que dedican su carrera a entender, no solo a litigar.
        </h2>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-3 gap-x-5 gap-y-12 sm:gap-x-10 md:gap-y-20">
        {team.map((member) => {
          const sheetId = `sheet-${member.slug}`;
          return (
            <>
            <!-- Card -->
            <article class="flex flex-col reveal">
              <button
                type="button"
                data-sheet-trigger={sheetId}
                class="group w-full text-left focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-line-strong"
                aria-haspopup="dialog"
                aria-controls={sheetId}
              >
                <div class="aspect-[4/5] overflow-hidden bg-surface-soft mb-6">
                  <img
                    src={member.photo}
                    alt={`Retrato de ${member.name}`}
                    class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                    loading="lazy"
                  />
                </div>
                <h3 class="link-underline font-display text-2xl md:text-3xl leading-[1.1] group-hover:text-fg-accent transition-colors">
                  {member.name}
                </h3>
                <p class="mt-2 text-base text-fg-muted">
                  {member.role}
                </p>
                {member.practiceAreas && member.practiceAreas.length > 0 && (
                  <p class="mt-4 text-sm text-fg-muted leading-relaxed">
                    {member.practiceAreas.join(" · ")}
                  </p>
                )}
              </button>
            </article>

            <!-- Sheet -->
            <Sheet id={sheetId} label={member.name}>
              <!-- Mobile layout (no photo) -->
              <div class="md:hidden">
                <p class="text-base text-fg-muted">
                  {member.role}
                </p>
                <h2 class="font-display text-3xl leading-[1.1] mt-2">{member.name}</h2>

                {member.practiceAreas && member.practiceAreas.length > 0 && (
                  <div class="mt-8">
                    <p class="font-display text-2xl leading-[1.1] text-fg">Áreas de práctica</p>
                    <ul class="mt-4 flex flex-wrap gap-2">
                      {member.practiceAreas.map((area) => (
                        <li class="text-sm px-3 py-1 bg-surface-soft border border-line rounded-full text-fg-soft">
                          {area}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                {member.experience && member.experience.length > 0 && (
                  <div class="mt-8 pt-8 border-t border-line">
                    <p class="font-display text-2xl leading-[1.1] text-fg">Experiencia</p>
                    <ul class="mt-4 list-disc space-y-3 pl-5 marker:text-fg-accent">
                      {member.experience.map((item) => (
                        <li class="text-sm text-fg-soft leading-relaxed">
                          {item}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                {member.education && member.education.length > 0 && (
                  <div class="mt-8 pt-8 border-t border-line">
                    <p class="font-display text-2xl leading-[1.1] text-fg">Formación académica</p>
                    <Timeline items={member.education} size="sm" />
                  </div>
                )}

                {member.languages && member.languages.length > 0 && (
                  <div class="mt-8 pt-8 border-t border-line">
                    <p class="font-display text-2xl leading-[1.1] text-fg">Idiomas</p>
                    <p class="mt-4 text-sm text-fg-soft">{member.languages.join(", ")}</p>
                  </div>
                )}

                {member.memberships && member.memberships.length > 0 && (
                  <div class="mt-8 pt-8 border-t border-line">
                    <p class="font-display text-2xl leading-[1.1] text-fg">Membresías</p>
                    <ul class="mt-4 list-disc space-y-3 pl-5 marker:text-fg-accent">
                      {member.memberships.map((item) => (
                        <li class="text-sm text-fg-soft leading-relaxed">
                          {item}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>

              <!-- Desktop layout (two columns) -->
              <div class="hidden md:grid md:grid-cols-12 md:gap-10 md:min-h-[32rem]">
                <!-- Left: photo + name + role -->
                <div class="md:col-span-3">
                  <div class="aspect-[4/5] overflow-hidden bg-surface-soft">
                    <img
                      src={member.photo}
                      alt={`Retrato de ${member.name}`}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  </div>
                  <h2 class="font-display text-4xl leading-[1.05] mt-6">{member.name}</h2>
                  <p class="mt-3 text-base text-fg-muted">
                    {member.role}
                  </p>
                </div>

                <!-- Right: all details -->
                <div class="md:col-span-8 md:col-start-5 overflow-y-auto max-h-[75dvh] pr-3">
                  {member.practiceAreas && member.practiceAreas.length > 0 && (
                    <div>
                      <p class="font-display text-3xl leading-[1.05] text-fg">Áreas de práctica</p>
                      <ul class="mt-5 flex flex-wrap gap-3">
                        {member.practiceAreas.map((area) => (
                          <li class="text-base px-4 py-2 bg-surface-soft border border-line rounded-full text-fg-soft">
                            {area}
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}

                  {member.experience && member.experience.length > 0 && (
                    <div class="mt-10 pt-10 border-t border-line">
                      <p class="font-display text-3xl leading-[1.05] text-fg">Experiencia</p>
                      <ul class="mt-5 list-disc space-y-4 pl-5 marker:text-fg-accent">
                        {member.experience.map((item) => (
                          <li class="text-base text-fg-soft leading-relaxed">
                            {item}
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}

                  {member.education && member.education.length > 0 && (
                    <div class="mt-10 pt-10 border-t border-line">
                      <p class="font-display text-3xl leading-[1.05] text-fg">Formación académica</p>
                    <Timeline items={member.education} />
                    </div>
                  )}

                  {member.memberships && member.memberships.length > 0 && (
                    <div class="mt-10 pt-10 border-t border-line">
                      <p class="font-display text-3xl leading-[1.05] text-fg">Membresías</p>
                      <ul class="mt-5 list-disc space-y-4 pl-5 marker:text-fg-accent">
                        {member.memberships.map((item) => (
                          <li class="text-base text-fg-soft leading-relaxed">
                            {item}
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}

                  {member.languages && member.languages.length > 0 && (
                    <div class="mt-10 pt-10 border-t border-line">
                      <p class="font-display text-3xl leading-[1.05] text-fg">Idiomas</p>
                      <p class="mt-5 text-base leading-relaxed text-fg-soft">
                        {member.languages.join(" · ")}
                      </p>
                    </div>
                  )}
                </div>
              </div>
            </Sheet>
            </>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ── CTA ─────────────────────────────────────────────────── -->
  <CTASection
    title="Si cree que somos el estudio adecuado para acompañar su operación, conversemos."
    description="Trabajamos con clientes que buscan asesoría profunda, no respuestas genéricas. Cuéntenos su situación y evaluamos juntos el mejor camino."
    buttonLabel="Contáctanos"
    href="/contacto"
  />
</BaseLayout>
