---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/ui/Button.astro";
import TextLink from "../../components/ui/TextLink.astro";
import { cms } from "../../lib/cms";
import { formatPublicationDate } from "../../lib/content";
import type { Publication } from "../../lib/types";

export async function getStaticPaths() {
  const publications = await cms.getPublications();
  return publications.map((publication) => ({
    params: { slug: publication.slug },
    props: { publication },
  }));
}

interface Props {
  publication: Publication;
}

const { publication } = Astro.props;

const allPublications = await cms.getPublications();
const related = allPublications
  .filter((p) => p.slug !== publication.slug)
  .slice(0, 2);
---

<BaseLayout title={publication.title} description={publication.excerpt}>
  <article>
    <header class="container-x pt-16 md:pt-24">
      <nav class="text-xs text-fg-subtle flex items-center gap-2" aria-label="Breadcrumb">
        <a href="/" class="hover:text-fg transition-colors">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/publicaciones" class="hover:text-fg transition-colors">Publicaciones</a>
        <span aria-hidden="true">/</span>
        <span class="text-fg-muted line-clamp-1">{publication.title}</span>
      </nav>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 mt-12 md:mt-20 pb-12 md:pb-16 border-b border-line">
        <div class="md:col-span-8">
          <div class="flex flex-wrap items-center gap-3 text-xs text-fg-muted">
            <span class="uppercase tracking-[var(--tracking-eyebrow)] text-fg-accent">
              {publication.category}
            </span>
            <span aria-hidden="true">·</span>
            <time datetime={publication.date}>{formatPublicationDate(publication.date)}</time>
            <span aria-hidden="true">·</span>
            <span>{publication.readingMinutes} min de lectura</span>
          </div>

          <h1 class="font-display text-4xl md:text-6xl lg:text-7xl mt-8 leading-[1.05] reveal">
            {publication.title}
          </h1>

          <p class="mt-10 text-xl md:text-2xl text-fg-muted leading-relaxed font-display reveal">
            {publication.excerpt}
          </p>
        </div>

        <div class="md:col-span-3 md:col-start-10 md:pt-4">
          <p class="eyebrow">Autor</p>
          <p class="mt-3 text-sm text-fg-soft">{publication.author}</p>
        </div>
      </div>
    </header>

    <div class="container-x py-16 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
        <div class="md:col-span-8">
          <div class="space-y-7 text-base md:text-lg text-fg-soft leading-[1.75] reveal">
            {publication.body.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>

          <div class="mt-16 pt-10 border-t border-line flex items-center justify-between">
            <TextLink href="/publicaciones" variant="muted" arrow="left">
              Volver a publicaciones
            </TextLink>
            <Button
              type="button"
              variant="ghost"
              showArrow={false}
              class="text-xs uppercase tracking-[var(--tracking-eyebrow)]"
              onclick="navigator.share ? navigator.share({title: document.title, url: window.location.href}) : navigator.clipboard.writeText(window.location.href)"
            >
              Compartir
            </Button>
          </div>
        </div>

        <aside class="md:col-span-3 md:col-start-10">
          <div class="sticky top-28 border-l border-fg-subtle/30 pl-6 reveal">
            <p class="eyebrow">Conversemos</p>
            <p class="mt-4 text-sm text-fg-muted leading-relaxed">
              ¿Este tema impacta su operación? Coordinemos una reunión para
              evaluarlo en su contexto.
            </p>
            <TextLink href="/contacto" class="mt-6">
              Contactar
            </TextLink>
          </div>
        </aside>
      </div>
    </div>
  </article>

  {related.length > 0 && (
    <section class="border-t border-line bg-surface-soft">
      <div class="container-x py-20 md:py-28">
        <p class="eyebrow reveal">También en publicaciones</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 mt-12">
          {related.map((item) => (
            <a href={`/publicaciones/${item.slug}`} class="group block reveal">
              <div class="flex items-center gap-3 text-xs text-fg-muted">
                <span class="uppercase tracking-[var(--tracking-eyebrow)] text-fg-accent">
                  {item.category}
                </span>
                <span aria-hidden="true">·</span>
                <time datetime={item.date}>{formatPublicationDate(item.date)}</time>
              </div>
              <h3 class="font-display text-2xl md:text-4xl mt-6 leading-[1.1] text-fg group-hover:text-fg-accent transition-colors">
                {item.title}
              </h3>
              <p class="mt-5 text-sm md:text-base text-fg-muted leading-relaxed">
                {item.excerpt}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
