---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";
import PageHero from "../components/PageHero.astro";
import PracticeAreaStackSection from "../components/practice/PracticeAreaStackSection.astro";
import TestimonialHorizontalSection from "../components/testimonials/TestimonialHorizontalSection.astro";
import PublicationItem from "../components/publications/PublicationItem.astro";
import Button from "../components/ui/Button.astro";
import TextLink from "../components/ui/TextLink.astro";
import { cms } from "../lib/cms";

const [settings, hero, indicators, areas, testimonials, publications] =
  await Promise.all([
    cms.getSiteSettings(),
    cms.getHomeHero(),
    cms.getIndicators(),
    cms.getPracticeAreas(),
    cms.getTestimonials(),
    cms.getPublications(),
  ]);

const featuredPublications = publications.slice(0, 3);
---

<BaseLayout
  description={settings.tagline}
  headerVariant="transparent"
>
  <PageHero
    videoSrc={hero.backgroundVideo?.url}
    imgSrc={hero.backgroundImage.url}
    imgAlt={hero.backgroundImage.alt}
    overlayOpacity={hero.overlayOpacity}
    minHeight={hero.minHeight}
  >
    <div class="grid grid-cols-1 md:grid-cols-12">
      <div class="md:col-span-10">
        <h1 class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-[88px] leading-[1.02] tracking-[-0.02em] text-fg-on-inverse reveal">
          {hero.title}
        </h1>
        <p class="mt-10 max-w-xl text-lg md:text-xl text-fg-on-inverse/75 leading-relaxed reveal">
          {hero.subtitle}
        </p>
        <div class="mt-12 flex flex-col sm:flex-row gap-6 sm:items-center reveal">
          <Button href="/contacto" tone="inverse" class="md:min-w-[240px]">Contactar</Button>
          <TextLink href="/areas-de-practica" variant="inverse" size="lg" class="self-start sm:self-auto">
            Áreas de práctica
          </TextLink>
        </div>
      </div>
    </div>
  </PageHero>

  <section aria-labelledby="trust-indicators" class="border-y border-line bg-surface-soft">
    <h2 id="trust-indicators" class="sr-only">Indicadores de confianza</h2>
    <div class="container-x py-14 md:py-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-y-10 gap-x-8 md:divide-x divide-line">
        {indicators.map((indicator, i) => (
          <div class={`reveal ${i > 0 ? "md:pl-10" : ""}`}>
            <div class="flex h-14 items-end md:h-16">
              {indicator.value === "LATAM" ? (
                <img
                  src="/flags2.svg"
                  alt="Banderas de Chile, Reino Unido y España"
                  width="152"
                  height="60"
                  loading="lazy"
                  decoding="async"
                  class="h-11 w-auto md:h-12"
                />
              ) : (
                <p class="font-display text-5xl md:text-6xl text-fg leading-none">
                  {indicator.value}
                </p>
              )}
            </div>
            <p class="mt-4 text-sm text-fg-muted max-w-[200px] leading-snug">
              {indicator.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section aria-labelledby="home-intro" class="container-x py-24 md:py-32 border-b border-line">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-16">
      <div class="md:col-span-3">
        <p class="eyebrow reveal">Una mirada experta</p>
      </div>

      <div class="md:col-span-8 md:col-start-5">
        <h2 id="home-intro" class="font-display text-4xl md:text-6xl leading-[1.05] reveal">
          Goñi & Cía. Abogados es un estudio especializado en riesgos complejos,
          seguros y responsabilidad civil.
        </h2>
        <div class="mt-10 reveal">
          <TextLink href="/nosotros" size="xl">Más sobre nosotros</TextLink>
        </div>
      </div>
    </div>
  </section>

  <PracticeAreaStackSection areas={areas} />

  <TestimonialHorizontalSection testimonials={testimonials} />

  <section aria-labelledby="publications" class="bg-surface-soft py-28 md:py-40 border-y border-line">
    <div class="container-x">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-end mb-16 md:mb-20">
        <div class="md:col-span-7">
          <p class="eyebrow reveal">Publicaciones</p>
          <h2 id="publications" class="font-display text-4xl md:text-6xl mt-6 leading-[1.05] reveal">
            Análisis técnicos que orientan decisiones de negocio.
          </h2>
        </div>
        <div class="md:col-span-4 md:col-start-9 md:text-right reveal">
          <TextLink href="/publicaciones" size="xl">Ver todas las publicaciones</TextLink>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-14">
        {featuredPublications.map((publication) => (
          <PublicationItem publication={publication} variant="card" showCta={false} />
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="¿Tiene un caso o un programa de seguros que evaluar con nosotros?"
    description="Coordinamos una reunión inicial para entender el contexto de su empresa o aseguradora, los riesgos críticos y la mejor forma de articular una asesoría que aporte valor desde el primer día."
    buttonLabel="Contáctanos"
  />
</BaseLayout>
