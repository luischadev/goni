---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/ui/Button.astro";
import TextLink from "../../components/ui/TextLink.astro";
import { cms } from "../../lib/cms";
import { getPracticeAreaIndicators } from "../../lib/practice-area-indicators";

const areas = await cms.getPracticeAreas();
---

<BaseLayout
  title="Áreas de práctica"
  description="Las áreas en las que el estudio concentra su práctica: seguros, recuperos, responsabilidad civil, derecho marítimo y transporte, corporativo y litigios."
  headerVariant="transparent"
>
  <section class="bg-surface-inverse text-fg-on-inverse">
    <div class="container-x pt-28 md:pt-36 pb-16 md:pb-24">
      <div class="grid grid-cols-1 gap-16 md:grid-cols-12 md:gap-y-20">
        <h1 class="font-display text-5xl md:col-span-10 md:text-7xl lg:text-[88px] leading-[0.95] tracking-[-0.035em] text-fg-on-inverse reveal">
          Profundidad técnica en los frentes que definen su industria.
        </h1>
        <p class="text-xl md:col-span-8 md:col-start-5 md:text-2xl leading-relaxed text-fg-on-inverse/75 reveal">
          Hemos construido nuestra práctica alrededor de los riesgos más complejos
          del mercado asegurador, logístico y marítimo. Cada área del estudio combina
          conocimiento académico de alto nivel con experiencia forense intensiva.
        </p>
      </div>
    </div>
  </section>

  <section class="border-y border-line">
    <div class="container-x divide-y divide-line">
      {areas.map((area) => {
        const indicators = getPracticeAreaIndicators(area);

        return (
          <article class="py-20 md:py-28">
            <div class="grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-x-16 md:gap-y-14">
              <div class="md:col-span-5">
                <a
                  href={`/areas-de-practica/${area.slug}`}
                  class="group/title inline-block focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-line-strong"
                >
                  <h2 class="link-underline font-display text-5xl md:text-7xl leading-[0.98] tracking-[-0.035em] text-fg transition-colors group-hover/title:text-fg-accent">
                    {area.title}
                  </h2>
                </a>
              </div>

              <div class="md:col-span-6 md:col-start-7">
                <p class="max-w-3xl text-xl md:text-2xl leading-relaxed text-fg-soft">
                  {area.intro}
                </p>
              </div>

              <div class="md:col-span-4">
                <div class="grid grid-cols-2 gap-8 md:gap-10">
                  {indicators.map((indicator) => (
                    <div>
                      <p class="font-display text-5xl md:text-6xl leading-none tracking-[-0.04em] text-fg">
                        {indicator.value}
                      </p>
                      <p class="mt-4 max-w-[10rem] text-sm md:text-base leading-snug text-fg-muted">
                        {indicator.label}
                      </p>
                    </div>
                  ))}
                </div>
              </div>

              <div class="md:col-span-6 md:col-start-7">
                <p class="flex max-w-3xl flex-wrap items-center text-sm md:text-base leading-relaxed text-fg-subtle">
                  {area.industries.map((industry, industryIndex) => (
                    <>
                      {industryIndex > 0 && (
                        <span aria-hidden="true" class="mx-2">
                          ·
                        </span>
                      )}
                      <span>{industry}</span>
                    </>
                  ))}
                </p>
              </div>

              <div class="md:col-span-12">
                <Button href={`/areas-de-practica/${area.slug}`}>
                  Más sobre el servicio
                </Button>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <section class="container-x py-24 md:py-32">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-end">
      <div class="md:col-span-8">
        <p class="eyebrow reveal">¿No encuentra su frente?</p>
        <h2 class="font-display text-3xl md:text-5xl mt-6 leading-[1.05] reveal">
          También asesoramos en operaciones donde la complejidad técnica<br class="hidden md:block" />
          y regulatoria exige una mirada experta.
        </h2>
      </div>
      <div class="md:col-span-4 md:text-right reveal">
        <TextLink href="/contacto">Conversar con el estudio</TextLink>
      </div>
    </div>
  </section>
</BaseLayout>
