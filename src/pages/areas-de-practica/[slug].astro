---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PracticeAreaCard from "../../components/practice/PracticeAreaCard.astro";
import PracticeAreaFeatureItem from "../../components/practice/PracticeAreaFeatureItem.astro";
import PracticeAreaNext from "../../components/practice/PracticeAreaNext.astro";
import Button from "../../components/ui/Button.astro";
import TextLink from "../../components/ui/TextLink.astro";
import { cms } from "../../lib/cms";
import type { PracticeArea } from "../../lib/types";

export async function getStaticPaths() {
  const areas = await cms.getPracticeAreas();
  return areas.map((area) => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

interface Props {
  area: PracticeArea;
}

const { area } = Astro.props;

const allAreas = await cms.getPracticeAreas();
const currentIndex = allAreas.findIndex((a) => a.slug === area.slug);
const nextArea = allAreas[(currentIndex + 1) % allAreas.length];
const otherAreas = allAreas.filter((a) => a.slug !== area.slug).slice(0, 3);
---

<BaseLayout
  title={area.title}
  description={area.shortDescription}
  headerVariant="transparent"
>
  <section class="bg-surface-inverse text-fg-on-inverse">
    <div class="container-x pt-28 md:pt-36 pb-16 md:pb-24">
      <nav
        class="text-xs text-fg-on-inverse/60 flex items-center gap-2 reveal"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-fg-on-inverse transition-colors">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/areas-de-practica" class="hover:text-fg-on-inverse transition-colors">
          Áreas de práctica
        </a>
        <span aria-hidden="true">/</span>
        <span class="text-fg-on-inverse/75">{area.title}</span>
      </nav>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-16 mt-16 md:mt-20">
        <div class="md:col-span-8">
          <p class="font-display text-3xl text-fg-on-inverse-accent reveal">{area.number}</p>
          <h1 class="font-display text-5xl md:text-7xl lg:text-[80px] leading-[1.02] mt-6 text-fg-on-inverse reveal">
            {area.title}
          </h1>
          <p class="mt-10 max-w-2xl text-lg md:text-xl text-fg-on-inverse/75 leading-relaxed reveal">
            {area.intro}
          </p>
        </div>
      </div>
    </div>
  </section>

  {area.features && area.features.length > 0 && (
    <section class="border-y border-line bg-surface-soft">
      <div class="container-x py-20 md:py-28">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16">
          <div class="md:col-span-4">
            <div class="md:sticky md:top-32 md:pb-8">
              <p class="eyebrow reveal">Cómo trabajamos</p>
              <h2 class="font-display text-4xl md:text-5xl mt-6 leading-[1.05] reveal">
                Una forma de trabajo pensada para casos complejos.
              </h2>
            </div>
          </div>

          <div class="md:col-span-8 reveal">
            <div class="divide-y divide-line border-t border-line">
              {area.features.map((feature) => (
                <PracticeAreaFeatureItem feature={feature} />
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="container-x py-24 md:py-32">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-end">
      <div class="md:col-span-8">
        <p class="eyebrow reveal">Próximo paso</p>
        <h2 class="font-display text-3xl md:text-5xl mt-6 leading-[1.05] reveal">
          Conversemos sobre cómo {area.title.toLowerCase()} aplica a su operación.
        </h2>
      </div>
      <div class="md:col-span-4 md:text-right reveal">
        <Button href="/contacto">Agendar consulta</Button>
      </div>
    </div>
  </section>

  <section class="border-t border-line bg-surface-soft">
    <div class="container-x py-20 md:py-28">
      <div class="flex items-end justify-between mb-12">
        <p class="eyebrow">Otras áreas del estudio</p>
        <TextLink href="/areas-de-practica" variant="subtle" class="hidden md:inline-flex">
          Ver todas las áreas
        </TextLink>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
        {otherAreas.map((other) => (
          <PracticeAreaCard area={other} />
        ))}
      </div>
    </div>
  </section>

  <section class="container-x py-16">
    <PracticeAreaNext area={nextArea} />
  </section>
</BaseLayout>
