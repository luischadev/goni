---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTASection from "../../components/CTASection.astro";
import PracticeAreaFeatureItem from "../../components/practice/PracticeAreaFeatureItem.astro";
import { cms } from "../../lib/cms";
import { getPracticeAreaHeroImage } from "../../lib/practice-area-hero-images";
import { getPracticeAreaIndicators } from "../../lib/practice-area-indicators";
import type { PracticeArea } from "../../lib/types";

export async function getStaticPaths() {
  const areas = await cms.getPracticeAreas();
  return areas.map((area) => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

interface Props {
  area: PracticeArea;
}

const { area } = Astro.props;

const allAreas = await cms.getPracticeAreas();
const otherAreas = allAreas.filter((a) => a.slug !== area.slug);
const heroImage = getPracticeAreaHeroImage(area.slug);
const heroIndicators = getPracticeAreaIndicators(area);
---

<BaseLayout
  title={area.title}
  description={area.shortDescription}
  headerVariant="solid"
>
  <section
    class="scroll-background-section scroll-background--surface-soft text-fg"
    data-scroll-background
    data-scroll-background-start="bottom 90%"
    data-scroll-background-end="bottom top"
  >
    <div class="container-x pt-20 md:pt-28 pb-16 md:pb-24">
      <nav
        class="text-sm text-fg-muted flex items-center gap-2 reveal"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-fg transition-colors">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/areas-de-practica" class="hover:text-fg transition-colors">
          Áreas de práctica
        </a>
        <span aria-hidden="true">/</span>
        <span class="text-fg">{area.title}</span>
      </nav>

      <div class="mt-16 md:mt-20">
        <div class="max-w-5xl">
          <h1 class="font-display text-6xl md:text-8xl lg:text-[104px] leading-[0.95] tracking-[-0.035em] reveal">
            {area.title}
          </h1>
          <p class="mt-10 max-w-4xl text-xl md:text-2xl leading-relaxed text-fg-soft reveal">
            {area.intro}
          </p>
        </div>

        <figure class="mt-16 aspect-video overflow-hidden bg-surface-soft">
          <img
            src={heroImage.src}
            alt={heroImage.alt}
            width="1800"
            height="1013"
            class="h-full w-full object-cover"
          />
        </figure>

        <div class="mt-10 grid grid-cols-2 gap-8 md:flex md:justify-start md:gap-14 reveal">
          {heroIndicators.map((indicator) => (
            <div>
              <p class="font-display text-5xl md:text-7xl lg:text-8xl leading-none tracking-[-0.04em] text-fg">
                {indicator.value}
              </p>
              <p class="mt-4 max-w-[10rem] text-sm md:text-base leading-snug text-fg-muted">
                {indicator.label}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {area.features && area.features.length > 0 && (
    <section class="border-b border-line bg-surface-soft">
      <div class="container-x py-20 md:py-28">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16">
          <div class="md:col-span-4">
            <div class="md:sticky md:top-32 md:pb-8">
              <p class="eyebrow reveal">Cómo trabajamos</p>
              <h2 class="font-display text-4xl md:text-5xl mt-6 leading-[1.05] reveal">
                Una forma de trabajo pensada para casos complejos.
              </h2>
            </div>
          </div>

          <div class="md:col-span-7 md:col-start-6 reveal">
            <div class="divide-y divide-line border-t border-line">
              {area.features.map((feature) => (
                <PracticeAreaFeatureItem feature={feature} />
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <CTASection
    title={`Conversemos sobre cómo ${area.title.toLowerCase()} aplica a su operación.`}
    description={`Coordinamos una reunión inicial para evaluar el contexto de su empresa, los riesgos críticos y la mejor forma de abordar ${area.title.toLowerCase()} con una estrategia clara.`}
    buttonLabel="Contáctanos"
  />

  <section class="border-t border-line bg-surface-soft">
    <div class="container-x py-20 md:py-28">
      <div class="flex items-end justify-between mb-12">
        <p class="eyebrow">Otras áreas del estudio</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-20">
        {otherAreas.map((other) => (
          <a
            href={`/areas-de-practica/${other.slug}`}
            class="group block border-t border-line py-8 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-line-strong"
          >
            <h3 class="link-underline font-display text-3xl md:text-4xl leading-[1.05] text-fg transition-colors group-hover:text-fg-accent">
              {other.title}
            </h3>
            <p class="mt-4 max-w-xl text-base leading-relaxed text-fg-muted">
              {other.shortDescription}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
