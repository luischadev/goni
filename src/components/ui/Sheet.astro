---
/**
 * Sheet — generic bottom sheet (mobile) / center modal (desktop).
 *
 * Usage:
 *   <Sheet id="my-sheet" label="Título accesible">
 *     ...contenido...
 *   </Sheet>
 *
 * To trigger it from anywhere:
 *   <button data-sheet-trigger="my-sheet">Abrir</button>
 */

interface Props {
  id: string;
  label?: string;
}

const { id, label = "Detalle" } = Astro.props;
---

<div
  id={id}
  class="sheet"
  role="dialog"
  aria-label={label}
  aria-modal="true"
  aria-hidden="true"
  data-sheet
>
  <!-- Backdrop -->
  <div class="sheet__backdrop" data-sheet-close aria-hidden="true"></div>

  <!-- Panel -->
  <div class="sheet__panel">
    <!-- Mobile drag handle -->
    <div class="sheet__handle md:hidden" aria-hidden="true"></div>

    <!-- Desktop close button -->
    <button
      class="sheet__close-btn hidden md:flex"
      data-sheet-close
      aria-label="Cerrar"
      type="button"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M14 4L4 14M4 4l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Scrollable body -->
    <div class="sheet__body">
      <slot />
    </div>
  </div>
</div>

<style>
  /* ── Base ─────────────────────────────────────────────── */
  .sheet {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: flex-end;
    pointer-events: none;
  }

  .sheet[aria-hidden="false"] {
    pointer-events: auto;
  }

  /* ── Backdrop ─────────────────────────────────────────── */
  .sheet__backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(15, 24, 34, 0.45);
    opacity: 0;
    transition: opacity 300ms ease;
    cursor: pointer;
  }

  .sheet[aria-hidden="false"] .sheet__backdrop {
    opacity: 1;
  }

  /* ── Panel (mobile: bottom sheet) ────────────────────── */
  .sheet__panel {
    position: relative;
    width: 100%;
    background: var(--color-surface);
    border-radius: 1rem 1rem 0 0;
    max-height: 92dvh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transform: translateY(100%);
    transition: transform 380ms cubic-bezier(0.32, 0.72, 0, 1);
    box-shadow: 0 -8px 40px rgba(15, 24, 34, 0.12);
  }

  .sheet[aria-hidden="false"] .sheet__panel {
    transform: translateY(0);
  }

  /* ── Mobile drag handle ───────────────────────────────── */
  .sheet__handle {
    width: 2.5rem;
    height: 4px;
    background: var(--color-line);
    border-radius: 9999px;
    margin: 0.875rem auto 0;
    flex-shrink: 0;
  }

  /* ── Scrollable body ──────────────────────────────────── */
  .sheet__body {
    overflow-y: auto;
    flex: 1;
    padding: 1.5rem 1.5rem 2.5rem;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
  }

  /* ── Close button (desktop only) ─────────────────────── */
  .sheet__close-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2.25rem;
    height: 2.25rem;
    align-items: center;
    justify-content: center;
    color: var(--color-fg-muted);
    border: 0;
    background: var(--color-surface);
    cursor: pointer;
    transition: color 150ms, background 150ms;
    z-index: 1;
  }

  .sheet__close-btn:hover {
    color: var(--color-fg);
    background: var(--color-surface-soft);
  }

  /* ── Desktop: center modal ────────────────────────────── */
  @media (min-width: 768px) {
    .sheet {
      align-items: center;
      justify-content: center;
    }

    .sheet__panel {
      width: min(92vw, 61rem);
      max-width: 61rem;
      border-radius: var(--radius-lg);
      max-height: 88dvh;
      transform: translateY(16px) scale(0.97);
      opacity: 0;
      transition:
        transform 300ms cubic-bezier(0.32, 0.72, 0, 1),
        opacity 250ms ease;
      box-shadow: 0 32px 80px rgba(15, 24, 34, 0.18);
    }

    .sheet[aria-hidden="false"] .sheet__panel {
      transform: translateY(0) scale(1);
      opacity: 1;
    }

    .sheet__body {
      padding: 4rem 4rem 4.5rem;
    }
  }
</style>

<script>
  /**
   * Sheet controller — singleton via module scope.
   * Handles open/close for every [data-sheet] element on the page.
   */

  function openSheet(id: string): void {
    const sheet = document.getElementById(id);
    if (!sheet || sheet.getAttribute("aria-hidden") === "false") return;
    sheet.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";

    // Focus first focusable element inside the panel
    requestAnimationFrame(() => {
      const focusable = sheet.querySelector<HTMLElement>(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      );
      focusable?.focus();
    });
  }

  function closeSheet(sheet: HTMLElement): void {
    sheet.setAttribute("aria-hidden", "true");
    const anyOpen = document.querySelectorAll('[data-sheet][aria-hidden="false"]').length > 0;
    if (!anyOpen) document.body.style.overflow = "";
  }

  function handleClick(e: MouseEvent): void {
    const trigger = (e.target as Element).closest<HTMLElement>("[data-sheet-trigger]");
    if (trigger) {
      openSheet(trigger.dataset.sheetTrigger!);
      return;
    }

    const closeTarget = (e.target as Element).closest<HTMLElement>("[data-sheet-close]");
    if (closeTarget) {
      const sheet = closeTarget.closest<HTMLElement>("[data-sheet]");
      if (sheet) closeSheet(sheet);
    }
  }

  function handleKeydown(e: KeyboardEvent): void {
    if (e.key !== "Escape") return;
    document.querySelectorAll<HTMLElement>('[data-sheet][aria-hidden="false"]').forEach(closeSheet);
  }

  function init(): void {
    document.removeEventListener("click", handleClick);
    document.removeEventListener("keydown", handleKeydown);
    document.addEventListener("click", handleClick);
    document.addEventListener("keydown", handleKeydown);
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
