---
import TextLink from "../ui/TextLink.astro";
import type { NavItem as NavItemType } from "../../lib/types";

interface Props {
  id: string;
  variant: "desktop" | "mobile";
  items: NavItemType[];
  parent: NavItemType;
}

const { id, variant, items, parent } = Astro.props;
---

{variant === "desktop" ? (
  <div
    id={id}
    data-nav-panel={id}
    hidden
    class="nav-dropdown fixed inset-x-0 top-20 md:top-24 z-[60] border-t border-line bg-surface text-fg shadow-sm"
  >
    <div class="container-x py-12 grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-4">
        <p class="font-display text-4xl leading-[1.02] tracking-[-0.02em] text-fg">
          {parent.label}
        </p>
        {parent.description && (
          <p class="mt-5 max-w-xs text-sm leading-relaxed text-fg-muted">
            {parent.description}
          </p>
        )}
        {parent.href && (
          <TextLink href={parent.href} class="mt-8">
            Ver todas
          </TextLink>
        )}
      </div>

      <ul class="md:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-6">
        {items.map((child) => (
          <li>
            <a
              href={child.href}
              class="group block py-1 transition-colors"
            >
              <span class="link-underline font-display text-2xl leading-[1.1] text-fg group-hover:text-fg-accent transition-colors">
                {child.label}
              </span>
              {child.description && (
                <span class="block mt-1 text-sm text-fg-muted leading-relaxed">
                  {child.description}
                </span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
) : (
  <div
    id={id}
    data-nav-panel={id}
    hidden
    class="nav-dropdown mt-3 pl-4 border-l border-line space-y-4"
  >
    {items.map((child) => (
      <a
        href={child.href}
        class="block text-xl text-fg-muted hover:text-fg transition-colors"
      >
        {child.label}
      </a>
    ))}
    {parent.href && (
      <a
        href={parent.href}
        class="block text-base text-fg-accent hover:text-fg transition-colors pt-1"
      >
        Ver todas →
      </a>
    )}
  </div>
)}
