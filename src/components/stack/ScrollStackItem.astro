---
interface Props {
  index: number;
  href?: string;
  class?: string;
  variant?: "default" | "split";
}

const { index, href, class: className = "", variant = "default" } = Astro.props;

const itemClass = ["scroll-stack-item", className]
  .filter(Boolean)
  .join(" ");

const innerClass =
  variant === "split"
    ? "relative block min-h-[28rem] overflow-hidden bg-surface shadow-[0_24px_80px_rgba(15,24,34,0.08)] md:min-h-[34rem]"
    : "relative block min-h-[28rem] overflow-hidden bg-surface p-6 shadow-[0_24px_80px_rgba(15,24,34,0.08)] sm:p-8 md:min-h-[34rem] md:p-14 lg:p-20";
---

<article
  class={itemClass}
  data-scroll-stack-item
  style={`--stack-index: ${index}`}
>
  {
    href ? (
      <a href={href} class={innerClass} data-scroll-stack-panel>
        <slot />
      </a>
    ) : (
      <div class={innerClass} data-scroll-stack-panel>
        <slot />
      </div>
    )
  }
</article>
