---
import type { Testimonial } from "../../lib/types";

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;
---

<section
  aria-labelledby="testimonials"
  class="horizontal-scroll-section bg-surface-inverse-soft text-fg-on-inverse"
  data-horizontal-scroll
>
  <div class="container-x pt-16 md:pt-40 pb-10 md:pb-16">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-16 items-end">
      <div class="md:col-span-7">
        <p class="eyebrow text-fg-on-inverse-accent reveal">
          Voces del mercado
        </p>
        <h2
          id="testimonials"
          class="font-display text-4xl md:text-6xl mt-6 leading-[1.05] text-fg-on-inverse reveal"
        >
          La confianza de quienes operan en los frentes más exigentes.
        </h2>
      </div>
      <p class="md:col-span-4 md:col-start-9 text-base md:text-lg text-fg-on-inverse/70 leading-relaxed reveal">
        Testimonios de equipos que enfrentan riesgos técnicos, disputas
        complejas y decisiones legales de alto impacto.
      </p>
    </div>
  </div>

  <div class="horizontal-scroll-pin" data-horizontal-scroll-pin>
    <div
      class="horizontal-scroll-viewport"
      data-horizontal-scroll-viewport
      aria-label="Testimonios"
    >
      <div class="container-x">
        <div class="horizontal-scroll-track" data-horizontal-scroll-track>
        {
          testimonials.map((testimonial) => (
            <figure class="testimonial-carousel-card flex min-h-[28rem] w-[82vw] max-w-[42rem] shrink-0 flex-col bg-surface-inverse text-fg-on-inverse p-6 md:w-[42rem] md:p-12 lg:p-14 shadow-[0_30px_90px_rgba(0,0,0,0.28)]">
              <span
                class="material-symbols-sharp text-4xl md:text-fg-on-inverse-accent md:leading-none"
                style={{
                  fontVariationSettings:
                    '"FILL" 0, "wght" 200, "GRAD" 0, "opsz" 48',
                }}
                aria-hidden="true"
              >
                format_quote
              </span>

              <blockquote class="mt-5 md:mt-8 font-display text-xl md:text-3xl leading-relaxed text-fg-on-inverse">
                “{testimonial.quote}”
              </blockquote>

              <figcaption class="mt-auto flex items-center gap-4 pt-4 md:pt-10">
                <img
                  src={testimonial.avatar}
                  alt=""
                  width="48"
                  height="48"
                  loading="lazy"
                  decoding="async"
                  class="size-12 shrink-0 rounded-full object-cover ring-1 ring-line-on-inverse/10"
                />
                <div>
                  <p class="text-sm md:text-base text-fg-on-inverse">
                    {testimonial.author}
                  </p>
                  <p class="mt-1 text-xs md:text-sm text-fg-on-inverse/65">
                    {testimonial.position} · {testimonial.company}
                  </p>
                </div>
              </figcaption>
            </figure>
          ))
        }
        </div>
      </div>
    </div>

    <div class="container-x mt-6 flex gap-3 md:hidden" aria-label="Controles del carrusel de testimonios">
      <button
        type="button"
        class="testimonial-carousel-control"
        data-testimonial-carousel-prev
        aria-label="Testimonio anterior"
      >
        <span class="material-symbols-sharp text-xl" aria-hidden="true">arrow_back</span>
      </button>
      <button
        type="button"
        class="testimonial-carousel-control"
        data-testimonial-carousel-next
        aria-label="Testimonio siguiente"
      >
        <span class="material-symbols-sharp text-xl" aria-hidden="true">arrow_forward</span>
      </button>
    </div>
  </div>
</section>

<script>
  import { initHorizontalScrollSections } from "../../scripts/horizontal-scroll";

  function initTestimonialCarouselControls() {
    const sections = document.querySelectorAll<HTMLElement>("[data-horizontal-scroll]");

    sections.forEach((section) => {
      if (section.dataset.carouselControlsInitialized === "true") return;
      section.dataset.carouselControlsInitialized = "true";

      const viewport = section.querySelector<HTMLElement>("[data-horizontal-scroll-viewport]");
      const prev = section.querySelector<HTMLButtonElement>("[data-testimonial-carousel-prev]");
      const next = section.querySelector<HTMLButtonElement>("[data-testimonial-carousel-next]");

      if (!viewport || !prev || !next) return;

      const getStep = () => {
        const card = section.querySelector<HTMLElement>(".testimonial-carousel-card");
        return card ? card.offsetWidth + 24 : viewport.clientWidth;
      };

      prev.addEventListener("click", () => {
        viewport.scrollBy({ left: -getStep(), behavior: "smooth" });
      });

      next.addEventListener("click", () => {
        viewport.scrollBy({ left: getStep(), behavior: "smooth" });
      });
    });
  }

  initHorizontalScrollSections();
  initTestimonialCarouselControls();
  document.addEventListener("astro:page-load", initHorizontalScrollSections);
  document.addEventListener("astro:page-load", initTestimonialCarouselControls);
</script>
