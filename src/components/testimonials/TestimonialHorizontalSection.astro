---
import type { Testimonial } from "../../lib/types";

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;
---

<section
  aria-labelledby="testimonials"
  class="horizontal-scroll-section bg-surface-inverse-soft text-fg-on-inverse"
  data-horizontal-scroll
>
  <div class="container-x pt-28 md:pt-40 pb-14 md:pb-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-16 items-end">
      <div class="md:col-span-7">
        <p class="eyebrow text-fg-on-inverse-accent reveal">
          Voces del mercado
        </p>
        <h2
          id="testimonials"
          class="font-display text-4xl md:text-6xl mt-6 leading-[1.05] text-fg-on-inverse reveal"
        >
          La confianza de quienes operan en los frentes más exigentes.
        </h2>
      </div>
      <p class="md:col-span-4 md:col-start-9 text-base md:text-lg text-fg-on-inverse/70 leading-relaxed reveal">
        Testimonios de equipos que enfrentan riesgos técnicos, disputas
        complejas y decisiones legales de alto impacto.
      </p>
    </div>
  </div>

  <div class="horizontal-scroll-pin" data-horizontal-scroll-pin>
    <div
      class="horizontal-scroll-viewport"
      data-horizontal-scroll-viewport
      aria-label="Testimonios"
    >
      <div class="container-x">
        <div class="horizontal-scroll-track" data-horizontal-scroll-track>
        {
          testimonials.map((testimonial) => (
            <figure class="flex min-h-[28rem] w-[82vw] max-w-[42rem] shrink-0 flex-col bg-surface-inverse text-fg-on-inverse p-8 md:w-[42rem] md:p-12 lg:p-14 shadow-[0_30px_90px_rgba(0,0,0,0.28)]">
              <span
                class="material-symbols-sharp text-fg-on-inverse-accent leading-none"
                style={{
                  fontSize: "56px",
                  fontVariationSettings:
                    '"FILL" 0, "wght" 200, "GRAD" 0, "opsz" 48',
                }}
                aria-hidden="true"
              >
                format_quote
              </span>

              <blockquote class="mt-6 md:mt-8 font-display text-2xl md:text-3xl leading-relaxed text-fg-on-inverse">
                “{testimonial.quote}”
              </blockquote>

              <figcaption class="mt-auto flex items-center gap-4 pt-8 md:pt-10">
                <img
                  src={testimonial.avatar}
                  alt=""
                  width="48"
                  height="48"
                  loading="lazy"
                  decoding="async"
                  class="size-12 shrink-0 rounded-full object-cover ring-1 ring-line-on-inverse/10"
                />
                <div>
                  <p class="text-sm md:text-base text-fg-on-inverse">
                    {testimonial.author}
                  </p>
                  <p class="mt-1 text-xs md:text-sm text-fg-on-inverse/65">
                    {testimonial.position} · {testimonial.company}
                  </p>
                </div>
              </figcaption>
            </figure>
          ))
        }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initHorizontalScrollSections } from "../../scripts/horizontal-scroll";

  initHorizontalScrollSections();
  document.addEventListener("astro:page-load", initHorizontalScrollSections);
</script>
