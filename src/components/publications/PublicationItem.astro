---
import TextLink from "../ui/TextLink.astro";
import { formatPublicationDate } from "../../lib/content";
import type { Publication } from "../../lib/types";

/**
 * PublicationItem
 *
 * Navigational element for a single publication. One component, three
 * variants used across the site:
 *   - "card"     → home, related lists, 3-column grids
 *   - "row"      → publications index, dense list
 *   - "featured" → publications index, top spotlight
 *
 * The optional `coverImage` field renders an aspect-ratio media on top
 * (card) or on the side (row / featured) so editorial layouts stay
 * consistent. When no cover is supplied, the component falls back to
 * a clean text-only layout without leaving empty space.
 */

type Variant = "card" | "row" | "featured";

interface Props {
  publication: Publication;
  variant?: Variant;
  showImage?: boolean;
  showAuthor?: boolean;
  reveal?: boolean;
  class?: string;
}

const {
  publication,
  variant = "card",
  showImage = true,
  showAuthor = variant !== "card",
  reveal = true,
  class: className = "",
} = Astro.props;

const href = `/publicaciones/${publication.slug}`;
const formattedDate = formatPublicationDate(publication.date);
const hasCover = showImage && Boolean(publication.coverImage);
const wrapperReveal = reveal ? "reveal" : "";
---

{variant === "card" && (
  <a
    href={href}
    class={`group flex flex-col focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-line-strong ${wrapperReveal} ${className}`}
  >
    {hasCover && (
      <div class="aspect-[4/3] overflow-hidden bg-surface-soft mb-6">
        <img
          src={publication.coverImage}
          alt={publication.coverImageAlt ?? ""}
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
        />
      </div>
    )}

    <div class="flex items-center gap-3 text-xs text-fg-muted">
      <span class="uppercase tracking-[var(--tracking-eyebrow)] text-fg-accent">
        {publication.category}
      </span>
      <span aria-hidden="true">·</span>
      <time datetime={publication.date}>{formattedDate}</time>
    </div>

    <h3 class="font-display text-2xl md:text-3xl mt-5 leading-[1.15] text-fg group-hover:text-fg-accent transition-colors">
      {publication.title}
    </h3>
    <p class="mt-4 text-sm md:text-base text-fg-muted leading-relaxed">
      {publication.excerpt}
    </p>

    {showAuthor && (
      <p class="mt-5 text-xs text-fg-subtle">Por {publication.author}</p>
    )}

    <TextLink
      as="span"
      variant="muted"
      size="sm"
      class="mt-6 text-fg-subtle group-hover:text-fg group-hover:gap-3"
    >
      Leer publicación
    </TextLink>
  </a>
)}

{variant === "row" && (
  <li class={wrapperReveal}>
    <a
      href={href}
      class={`group grid grid-cols-12 gap-6 py-10 md:py-14 items-center hover:bg-surface-soft/50 transition-colors px-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-line-strong ${className}`}
    >
      {hasCover ? (
        <div class="col-span-12 md:col-span-3">
          <div class="aspect-[4/3] overflow-hidden bg-surface-soft">
            <img
              src={publication.coverImage}
              alt={publication.coverImageAlt ?? ""}
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
            />
          </div>
        </div>
      ) : (
        <div class="col-span-12 md:col-span-2 text-xs text-fg-muted">
          <p class="uppercase tracking-[var(--tracking-eyebrow)] text-fg-accent">
            {publication.category}
          </p>
          <time class="mt-2 block" datetime={publication.date}>
            {formattedDate}
          </time>
        </div>
      )}

      <div class={`col-span-12 ${hasCover ? "md:col-span-6" : "md:col-span-7"}`}>
        {hasCover && (
          <div class="flex items-center gap-3 text-xs text-fg-muted">
            <span class="uppercase tracking-[var(--tracking-eyebrow)] text-fg-accent">
              {publication.category}
            </span>
            <span aria-hidden="true">·</span>
            <time datetime={publication.date}>{formattedDate}</time>
          </div>
        )}
        <h3 class={`font-display text-2xl md:text-4xl leading-[1.1] text-fg group-hover:text-fg-accent transition-colors ${hasCover ? "mt-4" : ""}`}>
          {publication.title}
        </h3>
        <p class="mt-4 text-sm md:text-base text-fg-muted leading-relaxed max-w-2xl">
          {publication.excerpt}
        </p>
      </div>

      <div class="col-span-12 md:col-span-3 md:text-right md:pl-6 text-xs text-fg-muted">
        {showAuthor && <p>Por {publication.author}</p>}
        <p class={showAuthor ? "mt-2" : ""}>{publication.readingMinutes} min de lectura</p>
        <TextLink
          as="span"
          size="sm"
          class="mt-6 group-hover:gap-3"
        >
          Leer
        </TextLink>
      </div>
    </a>
  </li>
)}

{variant === "featured" && (
  <a
    href={href}
    class={`group block container-x py-16 md:py-24 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[-4px] focus-visible:outline-line-strong ${wrapperReveal} ${className}`}
  >
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12 items-end">
      <div class="md:col-span-1">
        <p class="eyebrow text-fg-accent">Destacada</p>
      </div>

      {hasCover && (
        <div class="md:col-span-4 md:order-3">
          <div class="aspect-[4/3] overflow-hidden bg-surface">
            <img
              src={publication.coverImage}
              alt={publication.coverImageAlt ?? ""}
              loading="eager"
              decoding="async"
              class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
            />
          </div>
        </div>
      )}

      <div class={hasCover ? "md:col-span-7 md:order-2" : "md:col-span-11"}>
        <div class="flex items-center gap-3 text-xs text-fg-muted">
          <span class="uppercase tracking-[var(--tracking-eyebrow)] text-fg-accent">
            {publication.category}
          </span>
          <span aria-hidden="true">·</span>
          <time datetime={publication.date}>{formattedDate}</time>
          <span aria-hidden="true">·</span>
          <span>{publication.readingMinutes} min de lectura</span>
        </div>
        <h2 class="font-display text-3xl md:text-5xl mt-6 leading-[1.05] text-fg group-hover:text-fg-accent transition-colors">
          {publication.title}
        </h2>
        <p class="mt-6 max-w-2xl text-base md:text-lg text-fg-muted leading-relaxed">
          {publication.excerpt}
        </p>
        <div class="mt-8 flex items-center gap-6 text-sm text-fg-muted">
          {showAuthor && <span>Por {publication.author}</span>}
          <TextLink as="span" class="group-hover:gap-3">
            Leer publicación
          </TextLink>
        </div>
      </div>
    </div>
  </a>
)}
