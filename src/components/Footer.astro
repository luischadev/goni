---
import { cms } from "../lib/cms";

const settings = await cms.getSiteSettings();
const areas = await cms.getPracticeAreas();

const currentYear = new Date().getFullYear();
const footerLinkClass =
  "text-base leading-snug text-fg-on-inverse/85 transition-colors hover:text-fg-on-inverse";
---

<footer class="bg-surface-inverse text-fg-on-inverse">
  <div class="container-x py-20 md:py-28">
    <div class="grid grid-cols-1 gap-14 md:grid-cols-12 md:gap-12">
      <div class="md:col-span-3">
        <a href="/" class="inline-block" aria-label={`${settings.name} — Inicio`}>
          <img
            src="/goni-abogados-logo.png"
            alt={settings.legalName}
            width="1000"
            height="320"
            class="h-10 w-auto brightness-0 invert md:h-12"
          />
        </a>
      </div>

      <div class="md:col-span-3">
        <p class="eyebrow text-fg-on-inverse/55">Práctica</p>
        <ul class="mt-6 space-y-3.5">
          {areas.slice(0, 5).map((area) => (
            <li>
              <a
                href={`/areas-de-practica/${area.slug}`}
                class={footerLinkClass}
              >
                {area.title}
              </a>
            </li>
          ))}
          <li>
            <a
              href="/areas-de-practica"
              class={footerLinkClass}
            >
              Ver todas las áreas
            </a>
          </li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <p class="eyebrow text-fg-on-inverse/55">Estudio</p>
        <ul class="mt-6 space-y-3.5">
          <li><a href="/nosotros" class={footerLinkClass}>Nosotros</a></li>
          <li><a href="/publicaciones" class={footerLinkClass}>Publicaciones</a></li>
          <li><a href="/contacto" class={footerLinkClass}>Contacto</a></li>
        </ul>
      </div>

      <div class="md:col-span-4">
        <p class="eyebrow text-fg-on-inverse/55">Contacto</p>
        <address class="mt-6 space-y-3.5 text-base not-italic leading-relaxed text-fg-on-inverse/85">
          <p>
            {settings.address.street}<br />
            {settings.address.city}, {settings.address.region}<br />
            {settings.address.country}
          </p>
          <p>
            <a href={`tel:${settings.phone.replace(/\s+/g, "")}`} class="transition-colors hover:text-fg-on-inverse">
              {settings.phone}
            </a><br />
            <a href={`mailto:${settings.email}`} class="transition-colors hover:text-fg-on-inverse">
              {settings.email}
            </a>
          </p>
        </address>
      </div>
    </div>

    <div class="mt-20 flex flex-col items-start justify-between gap-4 border-t border-line-on-inverse/15 pt-8 text-xs text-fg-on-inverse/55 md:flex-row md:items-center">
      <p>© {currentYear} {settings.legalName}. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
