---
import TextLink from "./ui/TextLink.astro";
import { cms } from "../lib/cms";

const settings = await cms.getSiteSettings();
const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/areas-de-practica", label: "Áreas de práctica" },
  { href: "/publicaciones", label: "Publicaciones" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/contacto", label: "Contacto" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<header class="border-b border-line bg-surface/95 backdrop-blur sticky top-0 z-50">
  <div class="container-x flex items-center justify-between py-6 md:py-7">
    <a href="/" class="block shrink-0" aria-label={`${settings.name} — Inicio`}>
      <img
        src="/goni-abogados-logo.png"
        alt={settings.legalName}
        width="1000"
        height="320"
        class="h-8 w-auto md:h-10"
      />
    </a>

    <nav class="hidden md:flex items-center gap-9" aria-label="Navegación principal">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`text-[13px] tracking-wide transition-colors ${
            isActive(item.href)
              ? "text-fg"
              : "text-fg-muted hover:text-fg"
          }`}
        >
          {item.label}
          {isActive(item.href) && (
            <span class="block h-px w-full bg-surface-inverse mt-1"></span>
          )}
        </a>
      ))}
    </nav>

    <TextLink href="/contacto" size="sm" class="hidden md:inline-flex text-[13px]">
      Agendar consulta
    </TextLink>

    <button
      type="button"
      id="menu-toggle"
      class="md:hidden p-2 -mr-2 text-fg"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="3" y1="7" x2="21" y2="7"></line>
        <line x1="3" y1="17" x2="21" y2="17"></line>
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-line bg-surface"
  >
    <nav class="container-x flex flex-col py-6 gap-5" aria-label="Navegación móvil">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`text-base ${
            isActive(item.href)
              ? "text-fg"
              : "text-fg-muted"
          }`}
        >
          {item.label}
        </a>
      ))}
      <TextLink href="/contacto" class="mt-2 self-start">
        Agendar consulta
      </TextLink>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
