---
import { cms } from "../lib/cms";
import NavMenu from "./header/NavMenu.astro";
import TextLink from "./ui/TextLink.astro";

/**
 * Header
 *
 * Sticky/fixed top navigation with two configurable behaviors:
 *
 *   variant = "solid"        Look por defecto (fondo claro, tokens neutros).
 *                            Render con un spacer debajo para empujar el
 *                            contenido y no ocultarlo bajo el header fijo.
 *
 *   variant = "transparent"  Pensado para páginas con hero oscuro
 *                            (imagen/video). El header arranca transparente
 *                            usando tokens *-on-inverse y se vuelve sólido
 *                            cuando el usuario hace scroll. No se renderiza
 *                            spacer: el hero pasa por debajo desde y=0.
 *
 *   autoHide = true          Oculta el header al hacer scroll hacia abajo y
 *                            lo vuelve a mostrar al scrollear hacia arriba.
 *                            Respeta prefers-reduced-motion y el menú móvil.
 *
 *   scrollThreshold          Pixeles a partir de los cuales el header se
 *                            considera "scrolled" (cambio de look). El
 *                            auto-hide solo arranca después del doble de
 *                            ese valor para evitar saltos cerca del top.
 *
 * Los ítems del menú vienen de `cms.getMainNav()` para que estén listos
 * para Strapi/CMS. Cada ítem puede tener `children`: si los tiene, el item
 * se comporta como un trigger de dropdown (click); si no, navega directo.
 */
interface Props {
  variant?: "solid" | "transparent";
  autoHide?: boolean;
  scrollThreshold?: number;
}

const {
  variant = "solid",
  autoHide = true,
  scrollThreshold = 80,
} = Astro.props;

const [settings, navItems] = await Promise.all([
  cms.getSiteSettings(),
  cms.getMainNav(),
]);
const currentPath = Astro.url.pathname;
---

<header
  class="header fixed inset-x-0 top-0 z-50 overflow-visible"
  data-variant={variant}
  data-scrolled="false"
  data-hidden="false"
  data-autohide={String(autoHide)}
  data-threshold={scrollThreshold}
>
  <div class="container-x flex items-center justify-between py-6 md:py-7 overflow-visible">
    <a href="/" class="block shrink-0" aria-label={`${settings.name} — Inicio`}>
      <img
        src="/goni-abogados-logo.png"
        alt={settings.legalName}
        width="1000"
        height="320"
        class="header-logo h-8 w-auto md:h-10"
      />
    </a>

    <NavMenu items={navItems} variant="desktop" currentPath={currentPath} />

    <TextLink
      href="/contacto"
      variant="current"
      size="md"
      class="max-md:hidden md:inline-flex hover:text-[var(--header-nav-hover)]"
    >
      Agendar consulta
    </TextLink>

    <button
      type="button"
      id="menu-toggle"
      class="md:hidden p-2 -mr-2"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="3" y1="7" x2="21" y2="7"></line>
        <line x1="3" y1="17" x2="21" y2="17"></line>
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-line bg-surface text-fg h-[calc(100dvh-5rem)] overflow-y-auto"
  >
    <div class="container-x py-8">
      <NavMenu items={navItems} variant="mobile" currentPath={currentPath} />
      <TextLink href="/contacto" size="xl" class="mt-8">
        Agendar consulta
      </TextLink>
    </div>
  </div>
</header>

{variant === "solid" && (
  <div aria-hidden="true" class="h-20 md:h-24"></div>
)}

<script>
  const header = document.querySelector<HTMLElement>("header.header");
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  // Mobile menu toggle
  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
    // Header transparente → sólido cuando se abre el menú móvil
    if (!isOpen) {
      header?.setAttribute("data-mobile-menu-open", "true");
    } else {
      header?.removeAttribute("data-mobile-menu-open");
    }
  });

  // Nav dropdowns (click to open/close, single open at a time)
  const navTriggers = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-nav-toggle]")
  );
  let dropdownOpenTimer: number | undefined;
  const dropdownTransitionMs = 280;
  const dropdownHeaderGapMs = 120;

  function getPanelForTrigger(btn: HTMLButtonElement): HTMLElement | null {
    const group = btn.closest("[data-nav-group]");
    return group?.querySelector<HTMLElement>("[data-nav-panel]") ?? null;
  }

  function isHeaderTransparentAtTop(): boolean {
    return (
      header?.dataset.variant === "transparent" &&
      header?.dataset.scrolled === "false" &&
      !header.hasAttribute("data-dropdown-open")
    );
  }

  function revealDropdownPanel(panel: HTMLElement) {
    panel.hidden = false;
    panel.removeAttribute("hidden");
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        panel.setAttribute("data-open", "true");
      });
    });
  }

  function hideDropdownPanel(panel: HTMLElement) {
    panel.removeAttribute("data-open");

    window.setTimeout(() => {
      if (panel.getAttribute("data-open") === "true") return;
      panel.hidden = true;
      panel.setAttribute("hidden", "");
    }, dropdownTransitionMs);
  }

  function closeAllDropdowns({ preserveHeader = false, delayHeaderReset = false } = {}) {
    if (dropdownOpenTimer) {
      window.clearTimeout(dropdownOpenTimer);
      dropdownOpenTimer = undefined;
    }

    navTriggers.forEach((btn) => {
      btn.setAttribute("aria-expanded", "false");
      const panel = getPanelForTrigger(btn);
      if (panel) {
        hideDropdownPanel(panel);
      }
      const caret = btn.querySelector<HTMLElement>(".nav-caret");
      if (caret) caret.style.transform = "";
    });
    if (!preserveHeader) {
      if (delayHeaderReset) {
        window.setTimeout(() => {
          if (isAnyDropdownOpen()) return;
          header?.removeAttribute("data-dropdown-open");
        }, dropdownHeaderGapMs);
      } else {
        header?.removeAttribute("data-dropdown-open");
      }
    }
  }

  function isAnyDropdownOpen(): boolean {
    return navTriggers.some(
      (btn) => btn.getAttribute("aria-expanded") === "true"
    );
  }

  navTriggers.forEach((btn) => {
    btn.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();

      const panel = getPanelForTrigger(btn);
      if (!panel) return;

      const wasOpen = btn.getAttribute("aria-expanded") === "true";
      const hadOpenDropdown = isAnyDropdownOpen();
      const shouldWaitForHeader = !hadOpenDropdown && isHeaderTransparentAtTop();
      closeAllDropdowns({
        preserveHeader: !wasOpen && hadOpenDropdown,
        delayHeaderReset: wasOpen && header?.dataset.variant === "transparent",
      });

      if (!wasOpen) {
        btn.setAttribute("aria-expanded", "true");
        const caret = btn.querySelector<HTMLElement>(".nav-caret");
        if (caret) caret.style.transform = "rotate(180deg)";
        header?.setAttribute("data-dropdown-open", "true");

        if (shouldWaitForHeader) {
          dropdownOpenTimer = window.setTimeout(() => {
            revealDropdownPanel(panel);
            dropdownOpenTimer = undefined;
          }, dropdownHeaderGapMs);
        } else {
          revealDropdownPanel(panel);
        }
      }
    });
  });

  // Close dropdowns when clicking outside (deferred so open-click doesn't immediately close)
  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement | null;
    if (!target) return;
    if (target.closest("[data-nav-toggle]")) return;
    if (target.closest("[data-nav-group]")) return;
    if (target.closest("[data-nav-panel]")) return;
    closeAllDropdowns({
      delayHeaderReset: header?.dataset.variant === "transparent",
    });
  });

  // Close dropdowns on Escape
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeAllDropdowns({
        delayHeaderReset: header?.dataset.variant === "transparent",
      });
    }
  });

  // Header scroll behavior
  if (header) {
    const threshold = Number(header.dataset.threshold) || 80;
    const autoHide = header.dataset.autohide === "true";
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    const isMobileMenuOpen = () =>
      menu instanceof HTMLElement && !menu.classList.contains("hidden");

    let lastY = window.scrollY;
    let ticking = false;

    const update = () => {
      const y = window.scrollY;

      header.dataset.scrolled = y > threshold ? "true" : "false";

      const blockHide = isMobileMenuOpen() || isAnyDropdownOpen();

      if (autoHide && !blockHide && !reduceMotion && y > threshold * 2) {
        if (y > lastY + 4) header.dataset.hidden = "true";
        else if (y < lastY - 4) header.dataset.hidden = "false";
      } else {
        header.dataset.hidden = "false";
      }

      lastY = y;
      ticking = false;
    };

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true }
    );

    update();
  }
</script>
