---
import type { PracticeAreaFeature } from "../../lib/types";

interface Props {
  feature: PracticeAreaFeature;
  class?: string;
}

const { feature, class: className = "" } = Astro.props;
---

<article
  class={`py-10 md:py-14 grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 ${className}`}
>
  <span
    class="material-symbols-sharp text-4xl leading-none text-fg-muted md:col-span-1"
    aria-hidden="true"
  >
    {feature.icon}
  </span>

  <div class="md:col-span-10">
    <h3 class="font-display text-3xl md:text-4xl leading-[1.05] tracking-[-0.02em] text-fg">
      {feature.title}
    </h3>
    <p class="mt-4 max-w-xl text-base leading-relaxed text-fg-muted">
      {feature.description}
    </p>
    {feature.bullets && feature.bullets.length > 0 && (
      <ul class="mt-6 space-y-3 text-sm md:text-base leading-relaxed text-fg-muted">
        {feature.bullets.map((bullet) => (
          <li class="flex gap-3">
            <span
              class="mt-[0.7em] h-1.5 w-1.5 shrink-0 rounded-full bg-fg-muted/50"
              aria-hidden="true"
            />
            <span>{bullet}</span>
          </li>
        ))}
      </ul>
    )}
  </div>
</article>
