---
import type { PracticeArea } from "../../lib/types";

interface Props {
  area: PracticeArea;
  label?: string;
  class?: string;
  reveal?: boolean;
}

const {
  area,
  label = "Siguiente área",
  class: className = "",
  reveal = true,
} = Astro.props;

const href = `/areas-de-practica/${area.slug}`;
const wrapperClass = [
  "group flex items-center justify-between gap-6 py-8 border-t border-line",
  reveal ? "reveal" : "",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<a
  href={href}
  class={`${wrapperClass} focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-line-strong`}
>
  <div>
    <p class="eyebrow text-fg-subtle">{label}</p>
    <p class="font-display text-2xl md:text-3xl mt-3 text-fg group-hover:text-fg-accent transition-colors">
      {area.title}
    </p>
  </div>
  <span
    class="text-2xl text-fg-subtle group-hover:text-fg transition-colors"
    aria-hidden="true"
  >
    →
  </span>
</a>
