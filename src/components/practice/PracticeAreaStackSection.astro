---
import ScrollStackItem from "../stack/ScrollStackItem.astro";
import ScrollStackSection from "../stack/ScrollStackSection.astro";
import Button from "../ui/Button.astro";
import { getPracticeAreaHeroImage } from "../../lib/practice-area-hero-images";
import { getPracticeAreaIndicators } from "../../lib/practice-area-indicators";
import type { PracticeArea } from "../../lib/types";

interface Props {
  areas: PracticeArea[];
}

const { areas } = Astro.props;
---

<ScrollStackSection labelledBy="practice-areas" class="practice-area-stack">
  <div slot="header">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-12">
      <div class="md:col-span-6">
        <p class="eyebrow reveal">Áreas de práctica</p>
        <h2 id="practice-areas" class="font-display text-4xl md:text-6xl mt-6 leading-[1.05] reveal">
          Profundidad en los frentes donde se decide la operación.
        </h2>
      </div>
      <div class="md:col-span-5 md:col-start-8 md:pt-4">
        <p class="text-base md:text-lg text-fg-muted leading-relaxed reveal">
          Cada área del estudio combina práctica forense intensiva con
          conocimiento técnico de la industria. Trabajamos cerca de los equipos
          de operaciones de nuestros clientes para anticipar riesgos y construir
          estrategias procesales eficientes.
        </p>
      </div>
    </div>
  </div>

  {
    areas.map((area, index) => {
      const indicators = getPracticeAreaIndicators(area);
      const heroImage = getPracticeAreaHeroImage(area.slug);

      return (
      <ScrollStackItem index={index} variant="split">
        <div class="grid min-h-[28rem] grid-cols-1 md:min-h-[34rem] md:grid-cols-[minmax(0,1.3fr)_minmax(18rem,0.7fr)]">
          <div class="order-2 flex flex-col p-6 sm:p-8 md:order-1 md:p-14 lg:p-20">
            <a
              href={`/areas-de-practica/${area.slug}`}
              class="group/title inline-block focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-line-strong"
            >
              <h3 class="link-underline font-display text-4xl sm:text-5xl md:text-6xl leading-[1.02] md:leading-[0.98] tracking-[-0.03em] text-fg transition-colors group-hover/title:text-fg-accent">
                {area.title}
              </h3>
            </a>

            <p class="mt-5 max-w-4xl text-base sm:text-lg md:mt-10 md:text-xl text-fg leading-relaxed md:leading-snug">
              {area.shortDescription}
            </p>

            <p class="mt-6 flex flex-wrap items-center text-sm md:mt-10 md:text-sm text-fg-muted leading-relaxed">
              {area.industries.slice(0, 3).map((industry, industryIndex) => (
                <>
                  {industryIndex > 0 && (
                    <span aria-hidden="true" class="mx-2">
                      ·
                    </span>
                  )}
                  <span>{industry}</span>
                </>
              ))}
            </p>

            <div class="mt-auto pt-8 md:pt-14">
              <Button href={`/areas-de-practica/${area.slug}`}>
                Más sobre el servicio
              </Button>
            </div>
          </div>

          <div class="relative order-1 flex aspect-[16/9] overflow-hidden p-4 sm:p-5 md:order-2 md:aspect-auto md:p-14 lg:p-20">
            <div class="pointer-events-none absolute inset-0" aria-hidden="true">
              <img
                src={heroImage.src}
                alt=""
                class="h-full w-full object-cover"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-inverse/90 via-surface-inverse/55 to-surface-inverse/10 md:bg-gradient-to-l md:from-surface-inverse/90 md:via-surface-inverse/72 md:to-surface-inverse/35"></div>
            </div>

            <div class="relative z-10 mt-auto grid w-full grid-cols-4 gap-x-3 md:ml-auto md:w-auto md:grid-cols-2 md:gap-x-10 md:gap-y-8">
              {indicators.map((indicator) => (
                <div>
                  <p class="font-display text-2xl sm:text-3xl md:text-4xl lg:text-6xl leading-none tracking-[-0.04em] text-fg-on-inverse">
                    {indicator.value}
                  </p>
                  <p class="mt-2 max-w-[5rem] text-[0.65rem] leading-snug text-fg-on-inverse/75 sm:text-xs md:mt-3 md:max-w-[7rem] lg:text-sm">
                    {indicator.label}
                  </p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </ScrollStackItem>
      );
    })
  }
</ScrollStackSection>
