---
import TextLink from "../ui/TextLink.astro";
import type { PracticeArea } from "../../lib/types";

interface Props {
  area: PracticeArea;
  variant?: "row" | "detailed";
  class?: string;
  reveal?: boolean;
}

const {
  area,
  variant = "row",
  class: className = "",
  reveal = true,
} = Astro.props;

const href = `/areas-de-practica/${area.slug}`;
const liClass = [reveal ? "reveal" : "", className].filter(Boolean).join(" ");
---

<li class={liClass}>
  {
    variant === "row" ? (
      <a
        href={href}
        class="group grid grid-cols-12 gap-6 items-baseline py-8 md:py-10 px-2 hover:bg-surface-soft/60 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-line-strong"
      >
        <span class="col-span-2 md:col-span-1 font-display text-xl md:text-2xl text-fg-accent">
          {area.number}
        </span>
        <span class="col-span-10 md:col-span-5 font-display text-2xl md:text-4xl text-fg leading-[1.1] group-hover:text-fg-accent transition-colors">
          {area.title}
        </span>
        <span class="col-span-12 md:col-span-5 text-sm md:text-base text-fg-muted leading-relaxed">
          {area.shortDescription}
        </span>
        <span
          class="col-span-12 md:col-span-1 text-right text-fg-subtle group-hover:text-fg transition-colors text-xl"
          aria-hidden="true"
        >
          →
        </span>
      </a>
    ) : (
      <a
        href={href}
        class="group block py-12 md:py-16 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-line-strong"
      >
        <div class="grid grid-cols-12 gap-6 items-baseline">
          <span class="col-span-2 md:col-span-1 font-display text-xl md:text-2xl text-fg-accent">
            {area.number}
          </span>
          <div class="col-span-10 md:col-span-7">
            <h2 class="font-display text-3xl md:text-5xl leading-[1.05] text-fg group-hover:text-fg-accent transition-colors">
              {area.title}
            </h2>
            <p class="mt-5 max-w-2xl text-base text-fg-muted leading-relaxed">
              {area.shortDescription}
            </p>
            <div class="mt-6">
              <p class="eyebrow mb-3 text-fg-subtle">Industrias</p>
              <p class="text-sm text-fg-muted leading-snug">
                {area.industries.slice(0, 3).join(" · ")}
              </p>
            </div>
          </div>
          <div class="col-span-12 md:col-span-4 md:text-right md:pl-6">
            <TextLink as="span" class="group-hover:gap-3">
              Conocer más
            </TextLink>
          </div>
        </div>
      </a>
    )
  }
</li>
